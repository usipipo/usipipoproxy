# =============================================================================
# uSipipo Backend - Environment Configuration
# =============================================================================
# Copia este archivo como .env y configura los valores requeridos
# Los valores marcados con TU_... deben ser configurados manualmente
# NOTA: Las variables VPN se autogeneran con usipipo-server/install.sh
# =============================================================================

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
APP_ENV=development
DEBUG=true
API_PREFIX=/api/v1

# =============================================================================
# SECURITY CONFIGURATION (REQUIRED)
# =============================================================================
# Generar con: openssl rand -hex 32 (mínimo 32 bytes para seguridad)
# Ejemplo válido (64 caracteres hex = 32 bytes):
JWT_SECRET=change_me_in_production_use_openssl_rand_hex_32_minimum
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# =============================================================================
# TELEGRAM BOT CONFIGURATION
# =============================================================================
# Obtener TOKEN de @BotFather en Telegram
TELEGRAM_TOKEN=TU_TELEGRAM_BOT_TOKEN_AQUI

# =============================================================================
# DATABASE CONFIGURATION (REQUIRED)
# =============================================================================
# URL de conexión PostgreSQL
# Formato: postgresql+asyncpg://usuario:password@host:puerto/database
DATABASE_URL=postgresql+asyncpg://usipipo_backend_user:YOUR_SECURE_PASSWORD_HERE@localhost:5432/usipipo_backend_db

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_URL=redis://localhost:6379
REDIS_MAX_CONNECTIONS=10
REDIS_SOCKET_TIMEOUT=5.0
REDIS_RETRY_ON_TIMEOUT=true

# =============================================================================
# VPN - WIREGUARD CONFIGURATION
# =============================================================================
# Estas variables se autogeneran con usipipo-server/install.sh (opción WireGuard)
# Los valores por defecto son los que usa el script si no se especifican
WG_INTERFACE=wg0
WG_PATH=/etc/wireguard
WG_SERVER_PORT=51820
SERVER_IP=tu-ip-publica-aqui
WG_CLIENT_DNS_1=1.1.1.1
WG_CLIENT_DNS_2=1.0.0.1
# Variables adicionales que genera el script
WG_SERVER_IPV4=10.66.66.1
WG_SERVER_IPV6=fd42:42:42::1
WG_SERVER_PUBKEY=generada_por_setup_sh
WG_SERVER_PRIVKEY=generada_por_setup_sh
WG_ALLOWED_IPS=0.0.0.0/0,::/0
WG_ENDPOINT=tu-ip-publica:puerto

# =============================================================================
# OPTIONAL - PAYMENT GATEWAYS (Semana 3)
# =============================================================================
# TRON_DEALER_API_KEY=td_tu_api_key_aqui
# TRON_DEALER_WEBHOOK_SECRET=openssl_rand_hex_32_generate_me
# TRON_DEALER_SWEEP_WALLET=your_bsc_wallet_address
