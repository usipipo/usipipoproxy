# =============================================================================
# uSipipo Telegram Bot - Example Environment Configuration
# =============================================================================
# Copy to .env and configure with real values
# =============================================================================

# =============================================================================
# TELEGRAM BOT CONFIGURATION
# =============================================================================
TELEGRAM_TOKEN=your_telegram_bot_token_here
ADMIN_ID=your_telegram_admin_id_here
BOT_USERNAME=usipipobot

# =============================================================================
# BACKEND API CONFIGURATION
# =============================================================================
BACKEND_URL=https://usipipo.duckdns.org
API_PREFIX=/api/v1

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO
