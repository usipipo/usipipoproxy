# uSipipo Agent Configuration Template
# Copy this file to .env and fill in your values
# Generated: {{TIMESTAMP}}

# =============================================================================
# AGENT CONFIGURATION
# =============================================================================

# Agent API Key (for backend communication)
# Get this from your backend admin panel
AGENT_API_KEY={{YOUR_API_KEY}}

# Backend URL (HTTP or HTTPS)
# Replace <backend-host> and <port> with your backend details
BACKEND_URL=http://<backend-host>:<port>

# Server ID (unique identifier for this VPS)
# Use a descriptive name: <location>-<server-name>
SERVER_ID={{SERVER_ID}}

# =============================================================================
# VPN CONFIGURATION
# =============================================================================

# Outline Manager API URL
# Replace <outline-host>, <port>, and <api-key> with your Outline server details
OUTLINE_API_URL=http://<outline-host>:<port>/<api-key>

# WireGuard Configuration
# Replace <wg-interface>, <wg-host>, and <wg-port> with your WireGuard details
WG_INTERFACE={{WG_INTERFACE}}
WG_SERVER_IP={{WG_SERVER_IP}}
WG_SERVER_PORT={{WG_SERVER_PORT}}

# =============================================================================
# ADVANCED SETTINGS (Optional)
# =============================================================================

# Agent listening port (default: 8080)
AGENT_PORT=8080

# Metrics reporting interval in seconds (default: 60)
METRICS_INTERVAL=60

# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
LOG_LEVEL=INFO

# =============================================================================
# PLACEHOLDER REFERENCE
# =============================================================================
#
# Replace these placeholders with your actual values:
#
# {{YOUR_API_KEY}}         - Your agent API key from backend
# {{SERVER_ID}}            - Unique server identifier (e.g., us-east-1, de-1)
# {{WG_INTERFACE}}         - WireGuard interface name (e.g., wg0)
# {{WG_SERVER_IP}}         - WireGuard server IP or hostname
# {{WG_SERVER_PORT}}       - WireGuard server port (e.g., 51820)
# <backend-host>           - Backend server IP or domain
# <port>                   - Backend API port (e.g., 8001)
# <outline-host>           - Outline server IP or domain
# <api-key>                - Outline API authentication key
#
# =============================================================================
# EXAMPLES
# =============================================================================

# Production VPS Example:
# AGENT_API_KEY=agent_key_prod_us_east_1_abc123xyz
# BACKEND_URL=https://api.usipipo.duckdns.org:8001
# SERVER_ID=us-east-1-vps-1
# OUTLINE_API_URL=https://vpn1.example.com:8081/abc123xyz
# WG_INTERFACE=wg0
# WG_SERVER_IP=vpn1.example.com
# WG_SERVER_PORT=51820

# Development/Local Example:
# AGENT_API_KEY=dev_key_local
# BACKEND_URL=http://127.0.0.1:8001
# SERVER_ID=dev-local-1
# OUTLINE_API_URL=http://127.0.0.1:8081/local-key
# WG_INTERFACE=wg0
# WG_SERVER_IP=127.0.0.1
# WG_SERVER_PORT=51820

# Multi-Server Setup Example:
# Server 1 (USA): SERVER_ID=us-east-1
# Server 2 (Germany): SERVER_ID=eu-central-1
# Server 3 (Belgium): SERVER_ID=eu-west-1
